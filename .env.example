# NSI Platform Environment Configuration
# 复制此文件为 .env 并填入真实值

# ===================
# 基础设施
# ===================
DATABASE_URL=postgresql+asyncpg://nsi:nsi_dev@localhost:5432/nsi_platform
REDIS_URL=redis://localhost:6379/0
MINIO_ENDPOINT=localhost:9000
MINIO_BUCKET=nsi-ocr-temp

# ===================
# JWT认证
# ===================
JWT_SECRET=dev-secret-change-me

# ===================
# 阿里云短信 (生产必须替换)
# ===================
ALIYUN_ACCESS_KEY_ID=YOUR_ALIYUN_ACCESS_KEY_ID
ALIYUN_ACCESS_KEY_SECRET=YOUR_ALIYUN_ACCESS_KEY_SECRET
ALIYUN_SMS_SIGN_NAME=速通互联验证码
ALIYUN_SMS_TEMPLATE_CODE=SMS_12345678
ALIYUN_SMS_ENABLED=true

# ===================
# 邮件发送
# ===================
SMTP_HOST=smtp.163.com
SMTP_PORT=465
SMTP_USERNAME=YOUR_SMTP_USERNAME
SMTP_PASSWORD=YOUR_SMTP_PASSWORD
SMTP_FROM=YOUR_SMTP_FROM
SMTP_ENABLED=true

# ===================
# 微服务内部通信URL (Docker网络内)
# ===================
ACCOUNT_CENTER_URL=http://account-center:30311
POLICY_HUB_URL=http://policy-hub:30312
ACTUARIAL_URL=http://actuarial-engine:30313

# ===================
# 配置中心
# ===================
ADMIN_TOKEN=nsi-admin-2024
ENCRYPTION_KEY=dev-enc-key-32bytes-long-change-in-production

# ===================
# MinIO / S3
# ===================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ===================
# 前端 (nsi-mobile)
# ===================
VITE_API_BASE_URL=http://localhost:30310
