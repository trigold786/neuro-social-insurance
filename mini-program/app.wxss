page {
  background-color: #0a0f1e;
  color: #e8f0fe;
  font-family: 'JetBrains Mono', 'PingFang SC', 'Microsoft YaHei', monospace;
  font-size: 28rpx;
  line-height: 1.6;
}

.container {
  padding: 24rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.card {
  background-color: #0d1526;
  border: 1rpx solid #1a2332;
  border-radius: 8rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.card-title {
  font-size: 24rpx;
  color: #7b8fa6;
  text-transform: uppercase;
  letter-spacing: 2rpx;
  margin-bottom: 16rpx;
}

.btn-primary {
  background-color: rgba(0, 212, 255, 0.1);
  border: 1rpx solid rgba(0, 212, 255, 0.4);
  color: #00d4ff;
  font-family: 'JetBrains Mono', monospace;
  font-size: 28rpx;
  padding: 20rpx 32rpx;
  border-radius: 8rpx;
  text-align: center;
}

.btn-primary:active {
  background-color: rgba(0, 212, 255, 0.2);
}

.text-cyan { color: #00d4ff; }
.text-amber { color: #ffb800; }
.text-green { color: #00e5a0; }
.text-muted { color: #7b8fa6; }
.text-white { color: #e8f0fe; }

.bg-cyan { background-color: rgba(0, 212, 255, 0.1); }
.bg-amber { background-color: rgba(255, 184, 0, 0.1); }
.bg-green { background-color: rgba(0, 229, 160, 0.1); }

.number {
  font-family: 'JetBrains Mono', monospace;
  font-variant-numeric: tabular-nums;
}

.flex { display: flex; }
.flex-col { flex-direction: column; }
.items-center { align-items: center; }
.justify-between { justify-content: space-between; }
.gap-2 { gap: 16rpx; }
.gap-3 { gap: 24rpx; }
.gap-4 { gap: 32rpx; }
.mt-2 { margin-top: 16rpx; }
.mt-3 { margin-top: 24rpx; }
.mt-4 { margin-top: 32rpx; }
.mb-2 { margin-bottom: 16rpx; }
.mb-3 { margin-bottom: 24rpx; }
.mb-4 { margin-bottom: 32rpx; }
.p-3 { padding: 24rpx; }
.p-4 { padding: 32rpx; }
.rounded { border-radius: 8rpx; }
.text-sm { font-size: 24rpx; }
.text-xs { font-size: 20rpx; }
.text-lg { font-size: 32rpx; }
.text-xl { font-size: 40rpx; }
.font-bold { font-weight: bold; }
.uppercase { text-transform: uppercase; }
.tracking-wider { letter-spacing: 2rpx; }
.truncate { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.w-full { width: 100%; }
.h-full { height: 100%;; }
.min-h-screen { min-height: 100vh; }
.overflow-hidden { overflow: hidden; }
